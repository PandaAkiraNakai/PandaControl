# Copy to `keystore.properties` and fill with your release keystore.
# Generate one with:
#   keytool -genkey -v -keystore apppanda-release.jks \
#     -keyalg RSA -keysize 4096 -validity 36500 -alias apppanda
#
# This file is gitignored. NEVER commit your real keystore.properties.

storeFile=/absolute/path/to/apppanda-release.jks
storePassword=changeme
keyAlias=apppanda
keyPassword=changeme
